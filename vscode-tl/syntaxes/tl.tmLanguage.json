{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "TensorLogic",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#chars"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#functions"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.tl",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.tl",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.tl",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.tl",
                    "match": "\\\\."
                }
            ]
        },
        "chars": {
            "name": "string.quoted.single.tl",
            "match": "'([^'\\\\]|\\\\.)'",
            "captures": {
                "0": {
                    "name": "string.quoted.single.tl"
                }
            }
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.tl",
                    "match": "\\b(if|else|for|while|loop|in|return|break|continue|match)\\b"
                },
                {
                    "name": "keyword.other.tl",
                    "match": "\\b(fn|let|mut|struct|enum|impl|mod|use|as|where|pub|extern|self|trait|type)\\b"
                },
                {
                    "name": "constant.language.tl",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "keyword.operator.arrow.tl",
                    "match": "(->|<-|=>|:-)"
                },
                {
                    "name": "keyword.operator.logical.tl",
                    "match": "\\bnot\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.tl",
                    "match": "\\b(f32|f64|i8|i16|i32|i64|u8|u16|u32|u64|bool|usize|void|String|Char)\\b"
                },
                {
                    "name": "storage.type.container.tl",
                    "match": "\\b(Tensor|Vec|HashMap|Option|Result)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.tl",
                    "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.float.scientific.tl",
                    "match": "\\b[0-9]+[eE][+-]?[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.tl",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.tl",
                    "match": "(==|!=|<=|>=)"
                },
                {
                    "name": "keyword.operator.assignment.compound.tl",
                    "match": "(\\+=|-=|\\*=|/=|%=)"
                },
                {
                    "name": "keyword.operator.logical.tl",
                    "match": "(&&|\\|\\|)"
                },
                {
                    "name": "keyword.operator.range.tl",
                    "match": "\\.\\."
                },
                {
                    "name": "keyword.operator.scope.tl",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.tl",
                    "match": "(\\+|-|\\*|/|%|<|>|!|&|\\||\\^|=|\\.)"
                },
                {
                    "name": "punctuation.separator.tl",
                    "match": "(,|;|:)"
                }
            ]
        },
        "functions": {
            "name": "entity.name.function.tl",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\()"
        }
    },
    "scopeName": "source.tl"
}